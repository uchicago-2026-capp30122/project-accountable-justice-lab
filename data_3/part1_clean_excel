import pandas as pd

#Load dataset
df = pd.read_excel("part1.xlsx")

#Filter column
col = "puesto_perspectiva_genero"

#Only bring judges
filtro = df[col].isin([
    "Ministro",
    "Ministra",
    "Ministra Presidenta"
])

df_filtrado = df[filtro]

# Save new excel
df_filtrado.to_excel("compiled_dataset_filtrado.xlsx", index=False)

print("Filtrado guardado:", df_filtrado.shape)
